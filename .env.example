# Omnituum Marketing — Environment Variables
# Copy this file to .env and fill in your values.

# Secure Intake API endpoint
VITE_INTAKE_ENDPOINT=https://your-intake-endpoint.example.com

# Omnituum X25519 public key (hex-encoded)
VITE_OMNITUUM_X25519_PUB_HEX=

# Omnituum Kyber public key (base64-encoded)
VITE_OMNITUUM_KYBER_PUB_B64=
